# ========================================
# Course AI Tutor - Spring Boot 环境变量配置
# ========================================
# 复制此文件为 .env 并填入真实配置
# cp .env.example .env

# ----------------------------------------
# 数据库配置 (MySQL 8.0+)
# ----------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=course_ai_tutor
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ----------------------------------------
# AI 服务配置 (SiliconFlow)
# ----------------------------------------
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 获取方式: https://cloud.siliconflow.cn/account/ak
# 推荐模型: Qwen/Qwen2.5-Coder-32B-Instruct

# ----------------------------------------
# 服务端口配置
# ----------------------------------------
SERVER_PORT=8082

# ----------------------------------------
# JWT 安全配置
# ----------------------------------------
# 必须至少 256 位（32 字符以上），生产环境请更换
JWT_SECRET=your-secret-key-change-in-production-must-be-at-least-256-bits
# 默认 7 天（毫秒）
JWT_EXPIRATION_MS=604800000

# ----------------------------------------
# CORS 跨域配置
# ----------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3001
