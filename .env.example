# Course AI Tutor 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# AI API 配置
# ============================================
# SiliconFlow API Key (从 https://siliconflow.cn 获取)
OPENAI_API_KEY=your-siliconflow-api-key-here

# 或者使用 SILICONFLOW_API_KEY (openclaw-skills 使用)
SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# ============================================
# Spring AI 后端配置
# ============================================
# JWT 密钥（生产环境请使用强随机字符串，至少32位）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# JWT 过期时间（毫秒），默认7天
JWT_EXPIRATION_MS=604800000

# 服务器端口
SERVER_PORT=8082

# ============================================
# RAG 服务配置
# ============================================
RAG_PORT=8083

# ============================================
# Node.js 后端配置
# ============================================
BACKEND_PORT=8081

# JWT 密钥（Node.js 后端使用）
NODE_JWT_SECRET=your-nodejs-jwt-secret-key-minimum-32-characters

# JWT 过期时间
NODE_JWT_EXPIRES_IN=7d

# Bcrypt salt rounds (推荐 12-14)
BCRYPT_SALT_ROUNDS=12

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 前端配置
# ============================================
VITE_API_BASE_URL=http://localhost:8081/api
VITE_RAG_BASE_URL=http://localhost:8083/api

# ============================================
# CORS 配置（生产环境请设置具体域名）
# ============================================
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
